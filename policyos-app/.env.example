# Development example only. Generate a unique secret for every deployed environment,
# for example with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Production startup rejects this placeholder and secrets shorter than 32 bytes.
APP_ENV=development
SECRET_KEY=replace-with-a-cryptographically-random-secret-of-at-least-32-bytes
DATABASE_URL=postgresql+asyncpg://policyos:policyos@localhost:5432/policyos
REDIS_URL=redis://localhost:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=30

AI_PROVIDER=fake
OPENAI_API_KEY=replace-with-secret-manager-reference
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BACKOFF_SECONDS=0.5
OPENAI_STORE_RESPONSES=false
AI_DEFAULT_DATA_CLASSIFICATION=internal
AI_ALLOW_CONFIDENTIAL_EXTERNAL_PROVIDER=false
AI_PROVIDER_AUDIT_RETENTION_DAYS=365
AI_USAGE_RETENTION_DAYS=365
AI_REDACTION_ENABLED=true
# Comma-separated organization-specific terms; leave empty by default.
AI_REDACTION_CUSTOM_TERMS=
# Secure knowledge ingestion. Production ingestion remains blocked until a real
# MalwareScanner adapter is configured; NoOp scanning is local/test only.
KNOWLEDGE_MAX_UPLOAD_BYTES=25000000
KNOWLEDGE_ALLOWED_EXTENSIONS=.txt,.md,.pdf,.docx,.csv,.xlsx,.hwp,.hwpx
# Empty uses the operating system temporary directory.
KNOWLEDGE_TEMP_DIRECTORY=
KNOWLEDGE_INGESTION_TIMEOUT_SECONDS=30
# Deterministic chunking defaults. Token estimates are heuristic, not billing usage.
KNOWLEDGE_CHUNK_MAX_CHARACTERS=4000
KNOWLEDGE_CHUNK_TARGET_CHARACTERS=3000
KNOWLEDGE_CHUNK_OVERLAP_CHARACTERS=300
KNOWLEDGE_CHUNK_MIN_CHARACTERS=200
KNOWLEDGE_CHUNK_PRESERVE_PAGE_BOUNDARIES=true
KNOWLEDGE_CHUNK_PRESERVE_SECTION_BOUNDARIES=true
KNOWLEDGE_CHUNK_PRESERVE_TABLES=true
KNOWLEDGE_CHUNK_PRESERVE_LISTS=true
KNOWLEDGE_CHUNKING_STRATEGY_VERSION=1.0.0

# Embeddings (heuristic/vector usage is not billing data)
EMBEDDING_PROVIDER=fake
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_POLICY_VERSION=1.0.0

# Hybrid retrieval
HYBRID_LEXICAL_WEIGHT=0.5
HYBRID_VECTOR_WEIGHT=0.5
HYBRID_RRF_K=60
HYBRID_CANDIDATE_LIMIT=50
HYBRID_DEFAULT_TOP_K=10
HYBRID_MIN_SCORE=0.0

# Governed MCP (no endpoint or secret values)
MCP_ENABLED=false
MCP_DEFAULT_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=2
MCP_MAX_RESULT_BYTES=1000000
MCP_ALLOW_REMOTE_SERVERS=false
MCP_ALLOW_LOCAL_PROCESS_SERVERS=false
MCP_REQUIRE_HUMAN_APPROVAL_FOR_WRITES=true
MCP_CACHE_ENABLED=true
MCP_CACHE_TTL_SECONDS=300
MCP_ALLOW_STALE_CACHE=true
MCP_SERVER_ALLOWLIST=law-mcp,minutes-mcp,finance-mcp,internal-docs-mcp,public-data-mcp
MCP_TOOL_ALLOWLIST=
MCP_AUDIT_RETENTION_DAYS=365
